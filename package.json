    "color": "#180602",
    "theme": "dark"
  },
  "pricing": "Free",
  "repository": {
    "type": "git",
    "url": "https://github.com/ColinGamez/ColinsLaunchPad.git"
  },
  "homepage": "https://github.com/ColinGamez/ColinsLaunchPad#readme",
