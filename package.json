  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "launch pad",
    "dashboard",
    "workspace",
    "scripts",
    "terminal",
    "links",
    "developer tools",
