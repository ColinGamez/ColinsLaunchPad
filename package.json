{
  "name": "colins-launch-pad",
  "displayName": "Colin's Launch Pad",
  "description": "Open scripts, files, links, terminal actions, and Colin's tools from one fast VS Code dashboard.",
  "version": "0.1.0",
  "publisher": "ColinGamez",
